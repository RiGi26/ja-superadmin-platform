# ============================================================
# SUPABASE — Core DB (hxhusfkrlafxdnyasmsu) — standalone, akun owner
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=       # ⚠️ SERVER ONLY — jangan expose ke client

# ============================================================
# SUPABASE — Website Builder (chjgijlwhozeevrvhejt) — read-only lintas-project
# Dipakai dashboard /dashboard/website-orders (tabel orders ada di project WB, bukan Core DB).
# ============================================================
WB_SUPABASE_URL=
WB_SUPABASE_SERVICE_ROLE_KEY=    # ⚠️ SERVER ONLY — jangan expose ke client

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=https://ja-superadmin-platform.vercel.app
NEXT_PUBLIC_APP_NAME=ja-superadmin-platform

# ============================================================
# SUPERADMIN
# ============================================================
# Superadmin (fallback sebelum JWT hook aktif). KEDUA var di bawah boleh berisi
# banyak email dipisah koma. Pakai salah satu (atau dua-duanya).
SUPERADMIN_EMAIL=superadmin@japanarena.com
# SUPERADMIN_EMAILS=superadmindimas@webzoka.com,superadminriyadh@webzoka.com

# ============================================================
# RESEND (Email)
# ============================================================
RESEND_API_KEY=                  # ⚠️ SERVER ONLY
RESEND_FROM_EMAIL=noreply@japanarenacorp.com

# ============================================================
# BILLING LINK (Slice C — checkout self-service tenant)
# ============================================================
# Rahasia HMAC untuk token tautan checkout langganan. WAJIB identik di repo app
# tenant (mis. ja-lms-platform) yang me-MINT token dan di repo superadmin yang
# MEM-VERIFIKASI. Gunakan string acak panjang (mis. `openssl rand -hex 32`).
BILLING_LINK_SECRET=              # ⚠️ SERVER ONLY — sama di superadmin + app tenant

